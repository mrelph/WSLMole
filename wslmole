#!/usr/bin/env bash
# WSLMole - WSL System Optimization Tool
# https://github.com/mrelph/WSLMole
set -euo pipefail

# Resolve script directory (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Source all library modules
for lib in "$SCRIPT_DIR"/lib/*.sh; do
    # shellcheck source=/dev/null
    source "$lib"
done

# Load configuration
load_config

# Global output format
FORMAT="text"

# ── ASCII Art ───────────────────────────────────────────────────────
show_logo() {
    echo -e "${CYAN}"
    cat << 'LOGO'
 __      __  ___ _     __  __       _
 \ \    / / / __| |   |  \/  | ___ | | ___
  \ \/\/ /  \__ \ |__ | |\/| |/ _ \| |/ -_)
   \_/\_/   |___/____||_|  |_|\___/|_|\___|
LOGO
    echo -e "${NC}"
    echo -e "        ${BOLD}WSL System Optimization Tool${NC} v${WSLMOLE_VERSION}"
    echo ""
}

# ── Usage ───────────────────────────────────────────────────────────
show_usage() {
    show_logo
    echo -e "${BOLD}Usage:${NC} wslmole [command] [options]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo -e "  ${BOLD}clean${NC}              System cleanup (temp files, caches, logs)"
    echo -e "  ${BOLD}disk${NC} [path]        Disk usage analysis"
    echo -e "  ${BOLD}dev${NC} [path]         Developer artifact cleanup"
    echo -e "  ${BOLD}diagnose${NC} [type]    System diagnostics"
    echo -e "  ${BOLD}packages${NC} [action]  Package manager (apt + snap)"
    echo -e "  ${BOLD}wsl${NC} [action]       WSL-specific tools"
    echo -e "  ${BOLD}scan${NC}               Quick system health scan"
    echo -e "  ${BOLD}plan${NC}               Show a risk-labeled action plan"
    echo -e "  ${BOLD}fix${NC}                Auto-fix based on health scan"
    echo -e "  ${BOLD}help${NC} [command]     Show help for a command"
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo -e "  ${BOLD}-i${NC}, ${BOLD}--interactive${NC}  Launch inline interactive menu"
    echo -e "  ${BOLD}-q${NC}, ${BOLD}--quick${NC}        Run quick system scan"
    echo -e "  ${BOLD}-v${NC}, ${BOLD}--verbose${NC}      Enable verbose logging"
    echo -e "  ${BOLD}--format${NC} FORMAT    Output format: text (default) or json"
    echo -e "  ${BOLD}--yes${NC}              Skip confirmation prompts"
    echo -e "  ${BOLD}-h${NC}, ${BOLD}--help${NC}         Show this help message"
    echo -e "  ${BOLD}--version${NC}          Show version"
    echo ""
    echo -e "Run ${BOLD}wslmole${NC} with no arguments for a quick health scan."
    echo -e "Run ${CYAN}wslmole help <command>${NC} for command-specific options."
}

cmd_scan() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                echo -e "${BOLD}Usage:${NC} wslmole scan"
                echo ""
                echo "  Run a quick system health scan with score and recommendations."
                return 0
                ;;
            *)
                print_error "Unknown option: $1"
                echo -e "${BOLD}Usage:${NC} wslmole scan"
                return 1
                ;;
        esac
    done

    run_quick_scan
}

# ── Fix Command ────────────────────────────────────────────────────
cmd_fix() {
    PLAN_FIX_ONLY=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--dry-run) DRY_RUN=true; shift ;;
            --yes) FORCE=true; shift ;;
            --only)
                if [[ -z "${2:-}" ]]; then
                    print_error "--only requires a comma-separated category list"
                    return 1
                fi
                PLAN_FIX_ONLY="$2"
                shift 2
                ;;
            -h|--help)
                echo -e "${BOLD}Usage:${NC} wslmole fix [options]"
                echo ""
                echo "  Preview and apply low-risk cleanup actions from the action plan."
                echo ""
                echo -e "${BOLD}Options:${NC}"
                echo "  -n, --dry-run    Show the plan without applying actions"
                echo "  --only LIST      Apply only these automatic categories (logs,tmp)"
                echo "  --yes            Apply low-risk actions without prompting"
                echo "  -h, --help       Show this help"
                return 0
                ;;
            *) shift ;;
        esac
    done

    print_header "WSLMole Auto-Fix"

    plan_collect
    if [[ "${FORMAT:-text}" == "json" ]]; then
        plan_print_json
        return 0
    fi

    plan_print_text

    if ! plan_has_auto_actions; then
        echo ""
        print_success "No low-risk automatic cleanup actions are available."
        return 0
    fi

    if [[ "$DRY_RUN" == true ]]; then
        echo ""
        print_warning "DRY RUN mode - no changes were made"
        return 0
    fi

    echo ""
    if confirm "Apply low-risk cleanup actions now?"; then
        plan_apply_auto_actions
    else
        print_info "Auto-fix cancelled."
    fi
}

# ── Main CLI Parser ─────────────────────────────────────────────────
main() {
    local command=""
    local args=()
    local exit_code=0

    # Parse global flags and extract command
    while [[ $# -gt 0 ]]; do
        # Once a command is identified, pass all remaining args to it
        if [[ -n "$command" ]]; then
            args+=("$1")
            shift
            continue
        fi

        case "$1" in
            -h|--help)
                show_usage
                exit 0
                ;;
            --version)
                echo "WSLMole v${WSLMOLE_VERSION}"
                exit 0
                ;;
            -i|--interactive)
                run_interactive_menu
                exit 0
                ;;
            -q|--quick)
                run_quick_scan
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            --format)
                if [[ $# -lt 2 ]]; then
                    print_error "--format requires an argument"
                    exit 1
                fi
                case "$2" in
                    text|json)
                        FORMAT="$2"
                        ;;
                    *)
                        print_error "Invalid format: $2. Use 'text' or 'json'"
                        exit 1
                        ;;
                esac
                shift 2
                ;;
            --yes)
                FORCE=true
                shift
                ;;
            -*)
                # Pass unknown flags to subcommand
                args+=("$1")
                shift
                ;;
            *)
                command="$1"
                shift
                ;;
        esac
    done

    init_logging

    # No command = quick scan (best first-run experience)
    if [[ -z "$command" ]]; then
        run_quick_scan
        exit 0
    fi

    if [[ "$FORMAT" == "json" ]]; then
        exec 3>&1
        JSON_STDOUT_FD=3
        exec 1>&2
    fi

    # Dispatch to module
    case "$command" in
        help)
            if [[ ${#args[@]} -gt 0 ]]; then
                case "${args[0]}" in
                    clean) cmd_clean_help ;; disk) cmd_disk_help ;;
                    dev) cmd_dev_help ;; diagnose) cmd_diagnose_help ;;
                    packages) cmd_packages_help ;; wsl) cmd_wsl_help ;;
                    scan) cmd_scan --help ;;
                    plan) cmd_plan_help ;;
                    fix) cmd_fix --help ;;
                    *) print_error "Unknown command: ${args[0]}"; show_usage; exit 1 ;;
                esac
            else
                show_usage
            fi
            exit 0
            ;;
        clean)
            cmd_clean "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        disk)
            cmd_disk "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        dev)
            cmd_dev "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        diagnose)
            cmd_diagnose "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        packages)
            cmd_packages "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        wsl)
            cmd_wsl "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        scan)
            cmd_scan "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        plan)
            cmd_plan "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        fix)
            cmd_fix "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        *)
            print_error "Unknown command: $command"
            echo ""
            show_usage
            exit 1
            ;;
    esac

    exit $exit_code
}

main "$@"
