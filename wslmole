#!/usr/bin/env bash
# WSLMole - WSL System Optimization Tool
# https://github.com/mrelph/WSLMole
set -euo pipefail

# Resolve script directory (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Source all library modules
for lib in "$SCRIPT_DIR"/lib/*.sh; do
    # shellcheck source=/dev/null
    source "$lib"
done

# Load configuration
load_config

# Global output format
FORMAT="text"

# ── ASCII Art ───────────────────────────────────────────────────────
show_logo() {
    echo -e "${CYAN}"
    cat << 'LOGO'
 __      __  ___ _     __  __       _
 \ \    / / / __| |   |  \/  | ___ | | ___
  \ \/\/ /  \__ \ |__ | |\/| |/ _ \| |/ -_)
   \_/\_/   |___/____||_|  |_|\___/|_|\___|
LOGO
    echo -e "${NC}"
    echo -e "        ${BOLD}WSL System Optimization Tool${NC} v${WSLMOLE_VERSION}"
    echo ""
}

# ── Usage ───────────────────────────────────────────────────────────
show_usage() {
    show_logo
    cat << 'USAGE'
Usage: wslmole [command] [options]

Commands:
  clean              System cleanup (temp files, caches, logs)
  disk [path]        Disk usage analysis
  dev [path]         Developer artifact cleanup
  diagnose [type]    System diagnostics
  packages [action]  Package manager (apt + snap)
  wsl [action]       WSL-specific tools
  help [command]     Show help for a command

Options:
  -i, --interactive  Launch interactive TUI menu
  -q, --quick        Run quick system scan
  -v, --verbose      Enable verbose logging
  --format FORMAT    Output format: text (default) or json
  --yes              Skip confirmation prompts
  -h, --help         Show this help message
  --version          Show version

Run 'wslmole <command> --help' for command-specific options.
USAGE
}

# ── Main CLI Parser ─────────────────────────────────────────────────
main() {
    local command=""
    local args=()
    local exit_code=0

    # Parse global flags and extract command
    while [[ $# -gt 0 ]]; do
        # Once a command is identified, pass all remaining args to it
        if [[ -n "$command" ]]; then
            args+=("$1")
            shift
            continue
        fi

        case "$1" in
            -h|--help)
                show_usage
                exit 0
                ;;
            --version)
                echo "WSLMole v${WSLMOLE_VERSION}"
                exit 0
                ;;
            -i|--interactive)
                run_interactive_menu
                exit 0
                ;;
            -q|--quick)
                run_quick_scan
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            --format)
                if [[ $# -lt 2 ]]; then
                    print_error "--format requires an argument"
                    exit 1
                fi
                case "$2" in
                    text|json)
                        FORMAT="$2"
                        ;;
                    *)
                        print_error "Invalid format: $2. Use 'text' or 'json'"
                        exit 1
                        ;;
                esac
                shift 2
                ;;
            --yes)
                FORCE=true
                shift
                ;;
            -*)
                # Pass unknown flags to subcommand
                args+=("$1")
                shift
                ;;
            *)
                command="$1"
                shift
                ;;
        esac
    done

    init_logging

    # No command = interactive mode
    if [[ -z "$command" ]]; then
        run_interactive_menu
        exit 0
    fi

    # Dispatch to module
    case "$command" in
        help)
            if [[ ${#args[@]} -gt 0 ]]; then
                case "${args[0]}" in
                    clean) cmd_clean_help ;; disk) cmd_disk_help ;;
                    dev) cmd_dev_help ;; diagnose) cmd_diagnose_help ;;
                    packages) cmd_packages_help ;; wsl) cmd_wsl_help ;;
                    *) print_error "Unknown command: ${args[0]}"; show_usage; exit 1 ;;
                esac
            else
                show_usage
            fi
            exit 0
            ;;
        clean)
            cmd_clean "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        disk)
            cmd_disk "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        dev)
            cmd_dev "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        diagnose)
            cmd_diagnose "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        packages)
            cmd_packages "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        wsl)
            cmd_wsl "${args[@]+"${args[@]}"}" || exit_code=$?
            ;;
        *)
            print_error "Unknown command: $command"
            echo ""
            show_usage
            exit 1
            ;;
    esac

    exit $exit_code
}

main "$@"
